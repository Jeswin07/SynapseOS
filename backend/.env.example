APP_NAME=SynapseOS

# ==========================
# Database
# ==========================
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

# ==========================
# Authentication
# ==========================
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256

ACCESS_TOKEN_EXPIRE_MINUTES=65
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==========================
# Object Storage
# ==========================
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET_NAME=
MINIO_SECURE=false

# ==========================
# LLM
# ==========================
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_JUDGE_MODEL=llama-3.1-8b-instant

# ==========================
# Neo4j
# ==========================
NEO4J_URI=
NEO4J_USERNAME=
NEO4J_PASSWORD=

# ==========================
# Knowledge
# ==========================
KNOWLEDGE_COLLECTION=enterprise_docs
KNOWLEDGE_CHUNK_SIZE=384
KNOWLEDGE_CHUNK_OVERLAP=64
KNOWLEDGE_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.70
RAG_CANDIDATE_K=10
RAG_TOP_K=5
KNOWLEDGE_DEFAULT_SEARCH_LIMIT=20

RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSION=384

GENERATOR_TEMPERATURE=0.1
GENERATOR_MAX_TOKENS=700

# ==========================
# Application
# ==========================
ENVIRONMENT=development
LOG_LEVEL=INFO